{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Notari",
  "version": "0.1.0",
  "identifier": "com.dikrana.notari",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Notari - Proof of Work System",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "center": true,
        "visible": false
      },
      {
        "label": "popover",
        "title": "Notari",
        "width": 400,
        "height": 600,
        "minWidth": 400,
        "minHeight": 600,
        "maxWidth": 400,
        "maxHeight": 600,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": true,
        "center": false,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "url": "?tray=true"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "tray-capability",
          "description": "Capability for tray functionality",
          "permissions": [
            "core:tray:allow-new",
            "core:tray:allow-set-icon",
            "core:tray:allow-set-tooltip",
            "core:tray:allow-set-menu",
            "core:tray:allow-set-icon-as-template",
            "core:tray:allow-set-temp-dir-path",
            "core:tray:allow-set-title",
            "core:tray:allow-set-visible",
            "core:menu:allow-new",
            "core:menu:allow-append",
            "core:menu:allow-prepend",
            "core:menu:allow-insert",
            "core:menu:allow-remove",
            "core:menu:allow-remove-at",
            "core:menu:allow-items",
            "core:menu:allow-get",
            "core:menu:allow-popup",
            "core:menu:allow-create-default",
            "core:menu:allow-set-as-app-menu",
            "core:menu:allow-set-as-window-menu",
            "core:menu:allow-text",
            "core:menu:allow-is-enabled",
            "core:menu:allow-set-enabled",
            "core:menu:allow-set-text",
            "core:menu:allow-set-accelerator",
            "notification:default"
          ]
        }
      ]
    },
    "trayIcon": {
      "iconPath": "icons/tray/tray-icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "Notari - Proof of Work System"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "msi", "deb", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["icons/tray/*"],
    "category": "Productivity",
    "shortDescription": "Tamper-evident proof-of-work verification system",
    "longDescription": "Notari provides cryptographically secure proof-of-work verification through tamper-evident session capture, AI-powered analysis, and blockchain anchoring.",
    "copyright": "Copyright © 2025 Dikrana. All rights reserved.",
    "license": "MIT",
    "licenseFile": "../LICENSE"
  },
  "plugins": {}
}
